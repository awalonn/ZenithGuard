{
  "manifest_version": 3,
  "name": "ZenithGuard",
  "version": "2.16.0",
  "description": "An advanced ad & privacy blocker leveraging AI.",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "scripting",
    "activeTab",
    "tabs",
    "alarms",
    "webRequest",
    "webNavigation",
    "cookies",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "js/background/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "pages/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "pages/settings.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "css/ai_hider.css",
        "css/inspector.css",
        "css/zapper.css",
        "css/toast.css",
        "css/breach_warning.css",
        "css/theme.css",
        "pages/analyzer.html",
        "pages/logger.html",
        "rules/youtube_rules.json",
        "js/content/yt_interceptor.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "declarative_net_request": {
    "rule_resources": []
  }
}